{
  "name": "tarium-music-player",
  "version": "1.0.0",
  "description": "A cinematic, editorial music player with queue management and playback controls. Build with TypeScript and designed for seamless integration.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node --test --experimental-test-isolation=none dist/tests/DoublyLinkedList.test.js dist/tests/PlayerManager.test.js",
    "prepublishOnly": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoFzzz/Tarium.git"
  },
  "keywords": [
    "music-player",
    "typescript",
    "player-manager",
    "queue",
    "playback",
    "media-adapter"
  ],
  "author": "",
