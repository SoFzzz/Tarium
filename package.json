  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SoFzzz/Tarium/issues"
  },
  "homepage": "https://github.com/SoFzzz/Tarium#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "use": "^3.1.1"
  }
}
